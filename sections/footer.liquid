<footer class="footer" {{ section.shopify_attributes }}>
  <div class="footer__inner">
    <div class="footer__newsletter">
      <div class="footer__newsletter-text">
        {%- if section.settings.newsletter_heading != blank -%}
          <h2 class="footer__newsletter-heading">{{ section.settings.newsletter_heading }}</h2>
        {%- endif -%}
        {%- if section.settings.newsletter_text != blank -%}
          <p class="footer__newsletter-description">{{ section.settings.newsletter_text }}</p>
        {%- endif -%}
      </div>
      <div class="footer__newsletter-form">
        {% form 'customer', class: 'footer__form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="footer__form-row">
            <input
              type="email"
              name="contact[email]"
              class="footer__input"
              placeholder="{{ 'sections.footer.email_placeholder' | t }}"
              required
              autocomplete="email"
              aria-label="{{ 'sections.footer.email_placeholder' | t }}"
            >
            <button type="submit" class="btn btn--primary footer__submit">
              {{ 'sections.footer.subscribe' | t }}
            </button>
          </div>
          <p class="footer__disclaimer">
            {{ 'sections.footer.disclaimer' | t }}
          </p>
        {% endform %}
      </div>
    </div>

    <div class="footer__links">
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_column' -%}
          <div class="footer__column" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h3 class="footer__column-heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.menu != blank -%}
              <ul class="footer__list">
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}" class="footer__link">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="footer__bottom">
      <div class="footer__social">
        {%- if settings.social_instagram != blank -%}
          <a href="{{ settings.social_instagram }}" class="footer__social-link" aria-label="Instagram" rel="noopener" target="_blank">
