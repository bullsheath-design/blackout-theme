          </a>
        {%- endif -%}
        {%- if settings.social_facebook != blank -%}
          <a href="{{ settings.social_facebook }}" class="footer__social-link" aria-label="Facebook" rel="noopener" target="_blank">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_twitter != blank -%}
          <a href="{{ settings.social_twitter }}" class="footer__social-link" aria-label="X" rel="noopener" target="_blank">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_youtube != blank -%}
          <a href="{{ settings.social_youtube }}" class="footer__social-link" aria-label="YouTube" rel="noopener" target="_blank">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        {%- endif -%}
        {%- if settings.social_tiktok != blank -%}
          <a href="{{ settings.social_tiktok }}" class="footer__social-link" aria-label="TikTok" rel="noopener" target="_blank">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </a>
        {%- endif -%}
      </div>
      <div class="footer__copyright">
        <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'sections.footer.rights' | t }}</p>
      </div>
      <div class="footer__policies">
        {%- for policy in shop.policies -%}
          {%- if policy != blank -%}
            <a href="{{ policy.url }}" class="footer__policy-link">{{ policy.title }}</a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer {
    padding: 3rem 5%;
    border-top: 1px solid var(--color-border);
  }

  .footer__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer__newsletter {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--color-border);
  }

  .footer__newsletter-heading {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .footer__newsletter-description {
    margin: 0;
    font-size: 0.875rem;
    opacity: 0.7;
  }

  .footer__newsletter-form {
    max-width: 480px;
  }

  .footer__form-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.75rem;
  }

  .footer__input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    background: transparent;
    font-family: inherit;
    font-size: 0.875rem;
  }

  .footer__input:focus {
    outline: 2px solid var(--color-foreground);
    outline-offset: -2px;
  }

  .footer__submit {
    white-space: nowrap;
  }

  .footer__disclaimer {
    font-size: 0.75rem;
    opacity: 0.6;
    margin: 0.75rem 0 0;
  }

  .footer__links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--color-border);
  }

  .footer__column-heading {
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .footer__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__list li {
    margin-bottom: 0.5rem;
  }

  .footer__link {
    font-size: 0.875rem;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .footer__link:hover {
    opacity: 1;
  }

  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .footer__social {
    display: flex;
    gap: 0.75rem;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .footer__social-link:hover {
    opacity: 1;
  }

  .footer__social-link svg {
    width: 20px;
    height: 20px;
  }

  .footer__copyright p {
    font-size: 0.8125rem;
    opacity: 0.6;
    margin: 0;
  }

  .footer__policies {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer__policy-link {
    font-size: 0.8125rem;
    opacity: 0.6;
    text-decoration: underline;
  }

  .footer__policy-link:hover {
    opacity: 1;
  }

  @media (min-width: 768px) {
    .footer {
      padding: 4.5rem 5%;
    }

    .footer__links {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer {
      padding: 5rem 5%;
    }

    .footer__newsletter {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }

    .footer__newsletter-form {
      min-width: 25rem;
    }

    .footer__links {
      grid-template-columns: repeat(5, 1fr);
    }

    .footer__bottom {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.footer.name",
  "class": "section-footer",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "t:sections.footer.newsletter_heading",
      "default": "Join our newsletter"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "t:sections.footer.newsletter_text",
      "default": "Get exclusive deals, new product launches, and performance tips delivered to your inbox."
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "t:sections.footer.link_column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading",
          "default": "Quick links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "t:sections.footer.menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.footer.name",
      "blocks": [
        { "type": "link_column", "settings": { "heading": "Shop" } },
        { "type": "link_column", "settings": { "heading": "About" } },
        { "type": "link_column", "settings": { "heading": "Support" } },
        { "type": "link_column", "settings": { "heading": "Legal" } },
        { "type": "link_column", "settings": { "heading": "Follow us" } }
      ]
    }
  ]
}
{% endschema %}
