{%- assign collection = section.settings.collection -%}

<section class="featured-collection section-padding" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="featured-collection__header">
      {%- if section.settings.tagline != blank -%}
        <p class="featured-collection__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="featured-collection__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="featured-collection__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    <div class="featured-collection__grid" style="--columns: {{ section.settings.columns }};">
      {%- if collection != blank -%}
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          <div class="product-card">
            <a href="{{ product.url }}" class="product-card__link">
              <div class="product-card__media">
                {%- if product.featured_image != blank -%}
                  {{ product.featured_image | image_url: width: 600, height: 600, crop: 'center' | image_tag: alt: product.title, loading: 'lazy', class: 'product-card__image' }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'product-card__image product-card__placeholder' }}
                {%- endif -%}
              </div>
              <div class="product-card__info">
                {%- if section.settings.show_vendor -%}
                  <p class="product-card__vendor">{{ product.vendor }}</p>
                {%- endif -%}
                <h3 class="product-card__title">{{ product.title }}</h3>
                <p class="product-card__price">{{ product.price | money }}</p>
              </div>
            </a>
            {%- if section.settings.show_button -%}
              <div class="product-card__action">
                <a href="{{ product.url }}" class="btn--link">
                  {{ 'sections.featured_collection.view' | t }}
                  <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M6.158 3.135a.5.5 0 01.707.023l3.75 4a.5.5 0 010 .684l-3.75 4a.5.5 0 11-.73-.684L9.565 7.5 6.135 3.842a.5.5 0 01.023-.707z" fill="currentColor"/>
                  </svg>
                </a>
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="product-card">
            <div class="product-card__media">
              {{ 'product-1' | placeholder_svg_tag: 'product-card__image product-card__placeholder' }}
            </div>
            <div class="product-card__info">
              <p class="product-card__vendor">{{ 'sections.featured_collection.vendor' | t }}</p>
              <h3 class="product-card__title">{{ 'sections.featured_collection.product_title' | t }}</h3>
              <p class="product-card__price">$0.00</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.view_all_label != blank -%}
      {%- if collection != blank -%}
        <div class="featured-collection__footer">
          <a href="{{ collection.url }}" class="btn btn--secondary">
            {{ section.settings.view_all_label }}
          </a>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .featured-collection__header {
    max-width: 600px;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .featured-collection__tagline {
    font-weight: 600;
    font-size: 0.875rem;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .featured-collection__heading {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1.25rem;
  }

  .featured-collection__description {
    font-size: 1.0625rem;
    margin: 0;
    opacity: 0.8;
  }

  .featured-collection__grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
  }

  .product-card__link {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .product-card__media {
    overflow: hidden;
  }

  .product-card__image {
    width: 100%;
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .product-card__link:hover .product-card__image {
    transform: scale(1.03);
  }

  .product-card__placeholder {
    background: #f5f5f5;
  }

  .product-card__info {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .product-card__vendor {
    font-size: 0.8125rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.6;
  }

  .product-card__title {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    line-height: 1.4;
  }

  .product-card__price {
    font-weight: 600;
    margin: 0;
  }

  .product-card__action {
    padding: 0 1.5rem 1.5rem;
  }

  .product-card__action .btn--link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-weight: 600;
    font-size: 0.875rem;
  }

  .product-card__action .btn--link:hover {
    gap: 0.5rem;
  }

  .featured-collection__footer {
    text-align: center;
    margin-top: 3rem;
  }

  @media (min-width: 640px) {
    .featured-collection__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .featured-collection__grid {
      gap: 2rem;
    }

    .product-card__title {
      font-size: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .featured-collection__grid {
      grid-template-columns: repeat(var(--columns, 4), 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.featured_collection.name",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "t:labels.tagline",
      "default": "Products"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Shop our best sellers"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.featured_collection.collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:sections.featured_collection.products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:sections.featured_collection.columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:sections.featured_collection.show_vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "t:sections.featured_collection.show_button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "t:sections.featured_collection.view_all",
      "default": "View all"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_collection.name"
    }
  ]
}
{% endschema %}
