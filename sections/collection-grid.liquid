{%- assign collection = collection | default: section.settings.collection -%}

<section class="collection-grid section-padding" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="collection-grid__header">
      <div class="collection-grid__header-text">
        {%- if section.settings.tagline != blank -%}
          <p class="collection-grid__tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}
        <h1 class="collection-grid__heading">
          {%- if collection != blank -%}
            {{ collection.title }}
          {%- else -%}
            {{ section.settings.heading | default: 'Products' }}
          {%- endif -%}
        </h1>
        {%- if collection != blank -%}
          {%- if collection.description != blank -%}
            <p class="collection-grid__description">{{ collection.description }}</p>
          {%- endif -%}
        {%- elsif section.settings.description != blank -%}
          <p class="collection-grid__description">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.view_all_label != blank -%}
        {%- if collection != blank -%}
          <a href="{{ collection.url }}" class="btn btn--secondary collection-grid__view-all">
            {{ section.settings.view_all_label }}
          </a>
        {%- endif -%}
      {%- endif -%}
    </div>

    {%- if collection != blank -%}
      {%- paginate collection.products by section.settings.products_per_page -%}
        <div class="collection-grid__products" style="--columns: {{ section.settings.columns }};">
          {%- for product in collection.products -%}
            <div class="collection-grid__item">
              <a href="{{ product.url }}" class="collection-grid__image-link">
                {%- if product.featured_image != blank -%}
                  {{ product.featured_image | image_url: width: 600, height: 720, crop: 'center' | image_tag: alt: product.title, loading: 'lazy', class: 'collection-grid__image' }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'collection-grid__image collection-grid__placeholder' }}
                {%- endif -%}
              </a>
              <a href="{{ product.url }}" class="collection-grid__info">
                <div class="collection-grid__info-text">
                  <h3 class="collection-grid__product-title">{{ product.title }}</h3>
                  {%- if product.variants.size > 1 -%}
                    <span class="collection-grid__variant">{{ product.variants.first.title }}</span>
                  {%- endif -%}
                </div>
                <span class="collection-grid__price">{{ product.price | money }}</span>
              </a>
              {%- if section.settings.show_atc -%}
                {%- form 'product', product -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  <button type="submit" class="btn btn--secondary collection-grid__atc">
                    {{ 'sections.collection_grid.add_to_cart' | t }}
                  </button>
                {%- endform -%}
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="collection-grid__pagination">
            {{ paginate | default_pagination }}
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    {%- else -%}
      <div class="collection-grid__products" style="--columns: {{ section.settings.columns }};">
        {%- for i in (1..6) -%}
          <div class="collection-grid__item">
            <div class="collection-grid__image-link">
              {{ 'product-1' | placeholder_svg_tag: 'collection-grid__image collection-grid__placeholder' }}
            </div>
            <div class="collection-grid__info">
              <div class="collection-grid__info-text">
                <h3 class="collection-grid__product-title">{{ 'sections.collection_grid.product_title' | t }}</h3>
                <span class="collection-grid__variant">{{ 'sections.collection_grid.variant' | t }}</span>
              </div>
              <span class="collection-grid__price">$32</span>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .collection-grid__header {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .collection-grid__tagline {
    font-weight: 600;
    font-size: 0.875rem;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .collection-grid__heading {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .collection-grid__description {
    font-size: 1.0625rem;
    margin: 0;
    opacity: 0.8;
  }

  .collection-grid__view-all {
    display: none;
  }

  .collection-grid__products {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem 2rem;
  }

  .collection-grid__image-link {
    display: block;
    margin-bottom: 0.75rem;
  }

  .collection-grid__image {
    width: 100%;
    aspect-ratio: 5/6;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .collection-grid__image-link:hover .collection-grid__image {
    transform: scale(1.02);
  }

  .collection-grid__placeholder {
    background: #f5f5f5;
  }

  .collection-grid__info {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  .collection-grid__product-title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
  }

  .collection-grid__variant {
    font-size: 0.8125rem;
    opacity: 0.6;
  }

  .collection-grid__price {
    font-size: 1.0625rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .collection-grid__atc {
    width: 100%;
    margin-top: 0.75rem;
  }

  .collection-grid__pagination {
    display: flex;
    justify-content: center;
    margin-top: 3rem;
    gap: 0.5rem;
  }

  .collection-grid__pagination a,
  .collection-grid__pagination span {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    font-size: 0.875rem;
  }

  .collection-grid__pagination span.current {
    background: var(--color-foreground);
    color: var(--color-background);
    border-color: var(--color-foreground);
  }

  @media (min-width: 640px) {
    .collection-grid__products {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .collection-grid__header {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }

    .collection-grid__view-all {
      display: inline-flex;
    }
  }

  @media (min-width: 1024px) {
    .collection-grid__products {
      grid-template-columns: repeat(var(--columns, 3), 1fr);
      gap: 1.5rem 3rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.collection_grid.name",
  "class": "section-collection-grid",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "t:labels.tagline"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Products"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.collection_grid.collection"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "t:sections.collection_grid.products_per_page",
      "min": 6,
      "max": 24,
      "step": 3,
      "default": 12
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:sections.collection_grid.columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_atc",
      "label": "t:sections.collection_grid.show_atc",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "t:sections.collection_grid.view_all",
      "default": "View all"
    }
  ],
  "presets": [
    {
      "name": "t:sections.collection_grid.name"
    }
  ]
}
{% endschema %}
