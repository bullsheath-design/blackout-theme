<section class="stats-grid section-padding" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="stats-grid__header">
      <div class="stats-grid__header-left">
        {%- if section.settings.heading != blank -%}
          <h2 class="stats-grid__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      <div class="stats-grid__header-right">
        {%- if section.settings.description != blank -%}
          <p class="stats-grid__description">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
    </div>
    <div class="stats-grid__items" style="--columns: {{ section.settings.columns }};">
      {%- for block in section.blocks -%}
        <div class="stats-grid__item" {{ block.shopify_attributes }}>
          {%- if block.type == 'stat' -%}
            {%- if block.settings.label != blank -%}
              <h3 class="stats-grid__label">{{ block.settings.label }}</h3>
            {%- endif -%}
            {%- if block.settings.value != blank -%}
              <p class="stats-grid__value">{{ block.settings.value }}</p>
            {%- endif -%}
            <div class="stats-grid__divider"></div>
            {%- if block.settings.text != blank -%}
              <p class="stats-grid__text">{{ block.settings.text }}</p>
            {%- endif -%}
          {%- elsif block.type == 'image' -%}
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: alt: block.settings.image.alt, loading: 'lazy', class: 'stats-grid__image' }}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'stats-grid__image stats-grid__placeholder' }}
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .stats-grid__header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .stats-grid__heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    line-height: 1.2;
  }

  .stats-grid__description {
    font-size: 1.0625rem;
    margin: 0;
    line-height: 1.6;
  }

  .stats-grid__items {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .stats-grid__item {
    border: 1px solid var(--color-border);
    padding: 2rem;
    display: flex;
    flex-direction: column;
  }

  .stats-grid__label {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 2rem;
    line-height: 1.4;
  }

  .stats-grid__value {
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
    text-align: right;
    margin-top: auto;
  }

  .stats-grid__divider {
    height: 1px;
    width: 100%;
    background: var(--color-border);
    margin: 1rem 0;
  }

  .stats-grid__text {
    margin: 0;
    text-align: right;
    font-size: 0.9375rem;
    opacity: 0.7;
  }

  .stats-grid__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 3/2;
  }

  .stats-grid__placeholder {
    background: #f5f5f5;
  }

  @media (min-width: 768px) {
    .stats-grid__header {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }

    .stats-grid__items {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .stats-grid__items {
      grid-template-columns: repeat(var(--columns, 3), 1fr);
    }

    .stats-grid__header {
      gap: 5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.stats_grid.name",
  "class": "section-stats-grid",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Our impact in numbers"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:sections.stats_grid.columns",
      "min": 2,
      "max": 3,
      "step": 1,
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "t:sections.stats_grid.stat",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "t:sections.stats_grid.label",
          "default": "Customer reviews"
        },
        {
          "type": "text",
          "id": "value",
          "label": "t:sections.stats_grid.value",
          "default": "50,000+"
        },
        {
          "type": "text",
          "id": "text",
          "label": "t:labels.text",
          "default": "Five-star ratings from athletes who tested our formulas"
        }
      ]
    },
    {
      "type": "image",
      "name": "t:labels.image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.stats_grid.name",
      "blocks": [
        { "type": "stat", "settings": { "label": "Customer reviews", "value": "50,000+", "text": "Five-star ratings from athletes" } },
        { "type": "image" },
        { "type": "stat", "settings": { "label": "Products shipped", "value": "1M+", "text": "Units delivered worldwide" } },
        { "type": "stat", "settings": { "label": "Lab tests passed", "value": "100%", "text": "Every batch third-party verified" } }
      ]
    }
  ]
}
{% endschema %}
