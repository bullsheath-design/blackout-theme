<section
  class="split-feature section-padding"
  style="--image-position: {{ section.settings.image_position }};"
  {{ section.shopify_attributes }}
>
  <div class="container">
    <div class="split-feature__header">
      {%- if section.settings.tagline != blank -%}
        <p class="split-feature__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="split-feature__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="split-feature__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>
    <div class="split-feature__grid">
      <div class="split-feature__content">
        <div class="split-feature__content-inner">
          {%- if section.settings.content_tagline != blank -%}
            <p class="split-feature__content-tagline">{{ section.settings.content_tagline }}</p>
          {%- endif -%}
          {%- if section.settings.content_heading != blank -%}
            <h3 class="split-feature__content-heading">{{ section.settings.content_heading }}</h3>
          {%- endif -%}
          {%- if section.settings.content_text != blank -%}
            <p class="split-feature__content-text">{{ section.settings.content_text }}</p>
          {%- endif -%}
          <div class="split-feature__buttons">
            <a href="#" class="btn btn--secondary split-feature__scroll-top">
              {%- if section.settings.button_label != blank -%}
                {{ section.settings.button_label }}
              {%- else -%}
                Reclaim Your Edge &rarr;
              {%- endif -%}
            </a>
            {%- if section.settings.button_label_2 != blank -%}
              <a href="{{ section.settings.button_url_2 }}" class="btn--link">
                {{ section.settings.button_label_2 }}
                <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M6.158 3.135a.5.5 0 01.707.023l3.75 4a.5.5 0 010 .684l-3.75 4a.5.5 0 11-.73-.684L9.565 7.5 6.135 3.842a.5.5 0 01.023-.707z" fill="currentColor"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
      <div class="split-feature__media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag: alt: section.settings.image.alt, loading: 'lazy', class: 'split-feature__image' }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'split-feature__image split-feature__placeholder' }}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .split-feature__header {
    max-width: 600px;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .split-feature__tagline {
    font-weight: 600;
    font-size: 0.875rem;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .split-feature__heading {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1.25rem;
  }

  .split-feature__description {
    font-size: 1.0625rem;
    margin: 0;
    opacity: 0.8;
  }

  .split-feature__grid {
    display: grid;
    grid-template-columns: 1fr;
    border: 1px solid var(--color-border);
  }

  .split-feature__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 1.5rem;
  }

  .split-feature__content-tagline {
    font-size: 0.8125rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .split-feature__content-heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 1.25rem;
    line-height: 1.2;
  }

  .split-feature__content-text {
    margin: 0;
    line-height: 1.6;
  }

  .split-feature__buttons {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .split-feature__media {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .split-feature__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .split-feature__placeholder {
    background: #f5f5f5;
    aspect-ratio: 1;
  }

  @media (min-width: 768px) {
    .split-feature__grid {
      grid-template-columns: 1fr 1fr;
    }

    .split-feature__content {
      padding: 2rem;
    }

    .split-feature__buttons {
      margin-top: 2rem;
    }

    .split-feature__media {
      order: var(--image-position, 2);
    }
  }

  @media (min-width: 1024px) {
    .split-feature__content {
      padding: 3rem;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    document.querySelectorAll('.split-feature__scroll-top').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    });
  })();
{% endjavascript %}


{% schema %}
{
  "name": "t:sections.split_feature.name",
  "class": "section-split-feature",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.split_feature.section_header"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "t:labels.tagline"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "header",
      "content": "t:sections.split_feature.content_header"
    },
    {
      "type": "text",
      "id": "content_tagline",
      "label": "t:labels.tagline",
      "default": "Tagline"
    },
    {
      "type": "text",
      "id": "content_heading",
      "label": "t:labels.heading",
      "default": "Medium length section heading goes here"
    },
    {
      "type": "textarea",
      "id": "content_text",
      "label": "t:labels.text",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:labels.button_url"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "t:labels.button_label_2",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "button_url_2",
      "label": "t:labels.button_url_2"
    },
    {
      "type": "header",
      "content": "t:sections.split_feature.media_header"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:sections.split_feature.image_position",
      "options": [
        { "value": "1", "label": "t:options.position.left" },
        { "value": "2", "label": "t:options.position.right" }
      ],
      "default": "2"
    }
  ],
  "presets": [
    {
      "name": "t:sections.split_feature.name"
    }
  ]
}
{% endschema %}
