<section class="faq section-padding" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="faq__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="faq__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="faq__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>
    <div class="faq__list">
      {%- for block in section.blocks -%}
        <details class="faq__item" {{ block.shopify_attributes }}>
          <summary class="faq__question">
            <span>{{ block.settings.question }}</span>
            <svg class="faq__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
          </summary>
          <div class="faq__answer">
            {{ block.settings.answer }}
          </div>
        </details>
      {%- endfor -%}
    </div>
    {%- if section.settings.cta_heading != blank -%}
      <div class="faq__cta">
        <h3 class="faq__cta-heading">{{ section.settings.cta_heading }}</h3>
        {%- if section.settings.cta_text != blank -%}
          <p class="faq__cta-text">{{ section.settings.cta_text }}</p>
        {%- endif -%}
        {%- if section.settings.cta_button_label != blank -%}
          <a href="{{ section.settings.cta_button_url }}" class="btn btn--secondary">{{ section.settings.cta_button_label }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .faq__header {
    max-width: 600px;
    margin-bottom: 3rem;
  }

  .faq__heading {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .faq__description {
    font-size: 1.0625rem;
    margin: 0;
    opacity: 0.8;
  }

  .faq__item {
    border-bottom: 1px solid var(--color-border);
  }

  .faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    font-size: 1.125rem;
    font-weight: 700;
    cursor: pointer;
    list-style: none;
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__icon {
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  details[open] .faq__icon {
    transform: rotate(45deg);
  }

  .faq__answer {
    padding-bottom: 1.5rem;
    line-height: 1.6;
    opacity: 0.8;
  }

  .faq__cta {
    text-align: center;
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-border);
  }

  .faq__cta-heading {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .faq__cta-text {
    margin: 0 0 1.5rem;
    opacity: 0.8;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.faq.name",
  "class": "section-faq",
  "max_blocks": 20,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "header",
      "content": "t:sections.faq.cta_header"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "t:sections.faq.cta_heading",
      "default": "Still have questions?"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:labels.text"
    },
    {
      "type": "text",
      "id": "cta_button_label",
      "label": "t:labels.button_label",
      "default": "Contact us"
    },
    {
      "type": "url",
      "id": "cta_button_url",
      "label": "t:labels.button_url"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "t:sections.faq.question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "t:sections.faq.question",
          "default": "What makes Blackout different from other brands?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "t:sections.faq.answer",
          "default": "<p>Every product uses clinically researched doses with full label transparency. No proprietary blends, no filler, and every batch is third-party tested.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.faq.name",
      "blocks": [
        { "type": "question", "settings": { "question": "What makes Blackout different?" } },
        { "type": "question", "settings": { "question": "Are your products third-party tested?" } },
        { "type": "question", "settings": { "question": "What is your return policy?" } },
        { "type": "question", "settings": { "question": "Do you offer subscriptions?" } },
        { "type": "question", "settings": { "question": "Where do you ship?" } }
      ]
    }
  ]
}
{% endschema %}
