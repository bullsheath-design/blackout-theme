<section class="ingredient-list section-padding" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="ingredient-list__header">
      {%- if section.settings.tagline != blank -%}
        <p class="ingredient-list__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="ingredient-list__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="ingredient-list__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>
    <div class="ingredient-list__grid" style="--columns: {{ section.settings.columns }};">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.url | default: '#' }}" class="ingredient-list__item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 400, height: 400, crop: 'center' | image_tag: alt: block.settings.title, loading: 'lazy', class: 'ingredient-list__image' }}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'ingredient-list__image ingredient-list__placeholder' }}
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <h3 class="ingredient-list__title">{{ block.settings.title }}</h3>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .ingredient-list__header {
    max-width: 600px;
    margin-bottom: 3rem;
  }

  .ingredient-list__tagline {
    font-weight: 600;
    font-size: 0.875rem;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ingredient-list__heading {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .ingredient-list__description {
    font-size: 1.0625rem;
    margin: 0;
    opacity: 0.8;
  }

  .ingredient-list__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .ingredient-list__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    transition: opacity 0.2s ease;
  }

  .ingredient-list__item:hover {
    opacity: 0.7;
  }

  .ingredient-list__image {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
  }

  .ingredient-list__placeholder {
    background: #f5f5f5;
  }

  .ingredient-list__title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
  }

  @media (min-width: 768px) {
    .ingredient-list__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .ingredient-list__grid {
      grid-template-columns: repeat(var(--columns, 6), 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.ingredient_list.name",
  "class": "section-ingredient-list",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "t:labels.tagline"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Key ingredients"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:sections.ingredient_list.columns",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 6
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "t:sections.ingredient_list.ingredient",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.heading",
          "default": "Creatine monohydrate"
        },
        {
          "type": "url",
          "id": "url",
          "label": "t:labels.button_url"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.ingredient_list.name",
      "blocks": [
        { "type": "ingredient", "settings": { "title": "Creatine monohydrate" } },
        { "type": "ingredient", "settings": { "title": "Beta-alanine" } },
        { "type": "ingredient", "settings": { "title": "Citrulline malate" } },
        { "type": "ingredient", "settings": { "title": "Caffeine anhydrous" } },
        { "type": "ingredient", "settings": { "title": "Whey isolate" } },
        { "type": "ingredient", "settings": { "title": "Omega-3 fish oil" } }
      ]
    }
  ]
}
{% endschema %}
