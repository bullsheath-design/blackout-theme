<section class="testimonial-grid section-padding" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="testimonial-grid__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="testimonial-grid__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="testimonial-grid__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    <div class="testimonial-grid__items" style="--columns: {{ section.settings.columns }};">
      {%- for block in section.blocks -%}
        <div class="testimonial-grid__item" {{ block.shopify_attributes }}>
          <div class="testimonial-grid__stars" aria-label="{{ block.settings.rating }} {{ 'sections.testimonial_grid.out_of_5' | t }}">
            {%- for i in (1..5) -%}
              {%- if i <= block.settings.rating -%}
                <svg class="testimonial-grid__star testimonial-grid__star--filled" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M21.947 9.179a1.001 1.001 0 00-.868-.676l-5.701-.453-2.467-5.461a.998.998 0 00-1.822-.001L8.622 8.05l-5.701.453a1 1 0 00-.619 1.713l4.213 4.107-1.49 6.452a1 1 0 001.53 1.057L12 18.202l5.445 3.63a1.001 1.001 0 001.517-1.106l-1.829-6.4 4.536-4.082c.297-.268.406-.686.278-1.065z" fill="currentColor"/>
                </svg>
              {%- endif -%}
            {%- endfor -%}
          </div>
          {%- if block.settings.quote != blank -%}
            <blockquote class="testimonial-grid__quote">{{ block.settings.quote }}</blockquote>
          {%- endif -%}
          <div class="testimonial-grid__author">
            {%- if block.settings.avatar != blank -%}
              <div class="testimonial-grid__avatar-wrap">
                {{ block.settings.avatar | image_url: width: 112, height: 112, crop: 'center' | image_tag: alt: block.settings.name, loading: 'lazy', class: 'testimonial-grid__avatar' }}
              </div>
            {%- endif -%}
            <div class="testimonial-grid__author-info">
              {%- if block.settings.name != blank -%}
                <p class="testimonial-grid__name">{{ block.settings.name }}</p>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <p class="testimonial-grid__title">{{ block.settings.title }}</p>
              {%- endif -%}
            </div>
            {%- if block.settings.logo != blank -%}
              <div class="testimonial-grid__logo">
                {{ block.settings.logo | image_url: height: 48 | image_tag: alt: block.settings.name, loading: 'lazy' }}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .testimonial-grid__header {
    margin-bottom: 3rem;
  }

  .testimonial-grid__heading {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .testimonial-grid__description {
    font-size: 1.0625rem;
    margin: 0;
    opacity: 0.8;
  }

  .testimonial-grid__items {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .testimonial-grid__stars {
    display: flex;
    margin-bottom: 1.5rem;
  }

  .testimonial-grid__star {
    width: 24px;
    height: 24px;
    color: #d4d4d4;
  }

  .testimonial-grid__star--filled {
    color: #000;
  }

  .testimonial-grid__quote {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.4;
    margin: 0;
    font-style: normal;
  }

  .testimonial-grid__author {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-top: 1.5rem;
  }

  .testimonial-grid__avatar-wrap {
    margin-bottom: 1rem;
  }

  .testimonial-grid__avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
  }

  .testimonial-grid__name {
    font-weight: 600;
    margin: 0;
  }

  .testimonial-grid__title {
    margin: 0;
    font-size: 0.875rem;
    opacity: 0.7;
  }

  .testimonial-grid__author-info {
    margin-bottom: 0.75rem;
  }

  .testimonial-grid__logo img {
    max-height: 48px;
    width: auto;
  }

  @media (min-width: 768px) {
    .testimonial-grid__items {
      grid-template-columns: repeat(var(--columns, 3), 1fr);
      gap: 2rem;
    }

    .testimonial-grid__quote {
      font-size: 1.25rem;
    }
  }

  @media (min-width: 1024px) {
    .testimonial-grid__items {
      gap: 3rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.testimonial_grid.name",
  "class": "section-testimonial-grid",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Customer testimonials"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:sections.testimonial_grid.columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "t:sections.testimonial_grid.testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "t:sections.testimonial_grid.rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "t:sections.testimonial_grid.quote",
          "default": "\"Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique.\""
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "t:sections.testimonial_grid.avatar"
        },
        {
          "type": "text",
          "id": "name",
          "label": "t:sections.testimonial_grid.author_name",
          "default": "Name Surname"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.testimonial_grid.author_title",
          "default": "Position, Company name"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "t:sections.testimonial_grid.company_logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.testimonial_grid.name",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
