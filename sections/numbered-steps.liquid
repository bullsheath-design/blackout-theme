<section class="numbered-steps section-padding" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="numbered-steps__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="numbered-steps__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="numbered-steps__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>
    <div class="numbered-steps__list">
      {%- for block in section.blocks -%}
        <div class="numbered-steps__step" {{ block.shopify_attributes }}>
          <div class="numbered-steps__number-col">
            <span class="numbered-steps__number">{{ forloop.index | prepend: '00' | slice: -2, 2 }}</span>
          </div>
          <div class="numbered-steps__progress">
            <div class="numbered-steps__line"></div>
          </div>
          <div class="numbered-steps__content">
            {%- if block.settings.tagline != blank -%}
              <p class="numbered-steps__tagline">{{ block.settings.tagline }}</p>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h3 class="numbered-steps__step-heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="numbered-steps__text">{{ block.settings.text }}</p>
            {%- endif -%}
            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_url }}" class="btn btn--secondary numbered-steps__btn">{{ block.settings.button_label }}</a>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .numbered-steps__header {
    max-width: 600px;
    margin-bottom: 3rem;
  }

  .numbered-steps__heading {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .numbered-steps__description {
    font-size: 1.0625rem;
    margin: 0;
    opacity: 0.8;
  }

  .numbered-steps__step {
    display: flex;
    gap: 1.5rem;
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
  }

  .numbered-steps__number {
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1;
    opacity: 0.15;
  }

  .numbered-steps__progress {
    display: none;
  }

  .numbered-steps__tagline {
    font-weight: 600;
    font-size: 0.875rem;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .numbered-steps__step-heading {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .numbered-steps__text {
    margin: 0;
    line-height: 1.6;
    opacity: 0.8;
  }

  .numbered-steps__btn {
    margin-top: 1.5rem;
  }

  @media (min-width: 768px) {
    .numbered-steps__number {
      font-size: 7rem;
    }

    .numbered-steps__step {
      gap: 3rem;
      padding: 3rem 0;
    }
  }

  @media (min-width: 1024px) {
    .numbered-steps__number {
      font-size: 10rem;
    }

    .numbered-steps__number-col {
      flex-shrink: 0;
      width: 200px;
      position: sticky;
      top: 20%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.numbered_steps.name",
  "class": "section-numbered-steps",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:labels.description"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "t:sections.numbered_steps.step",
      "settings": [
        {
          "type": "text",
          "id": "tagline",
          "label": "t:labels.tagline",
          "default": "Filter"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading",
          "default": "Sort by category"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:labels.text",
          "default": "Narrow by ingredient type, form, or dietary preference."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "t:labels.button_label"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "t:labels.button_url"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.numbered_steps.name",
      "blocks": [
        { "type": "step", "settings": { "tagline": "Filter", "heading": "Sort by category" } },
        { "type": "step", "settings": { "tagline": "Compare", "heading": "Read the label" } },
        { "type": "step", "settings": { "tagline": "Choose", "heading": "Pick your formula" } },
        { "type": "step", "settings": { "tagline": "Subscribe", "heading": "Save with auto-ship" } }
      ]
    }
  ]
}
{% endschema %}
