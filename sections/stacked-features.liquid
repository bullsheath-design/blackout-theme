<section class="stacked-features" {{ section.shopify_attributes }}>
  <div class="stacked-features__wrapper">
    {%- for block in section.blocks -%}
      <div
        class="stacked-features__panel"
        style="--panel-index: {{ forloop.index0 }};"
        {{ block.shopify_attributes }}
      >
        <div class="stacked-features__panel-inner">
          <div class="stacked-features__header">
            <a href="{{ block.settings.link_url | default: '#' }}" class="stacked-features__trigger">
              <span class="stacked-features__number">{{ forloop.index | prepend: '00' | slice: -2, 2 }}</span>
              <h3 class="stacked-features__trigger-title">{{ block.settings.trigger_title }}</h3>
            </a>
          </div>
          <div class="stacked-features__body">
            <div class="stacked-features__grid">
              <div class="stacked-features__content">
                {%- if block.settings.tagline != blank -%}
                  <p class="stacked-features__tagline">{{ block.settings.tagline }}</p>
                {%- endif -%}
                {%- if block.settings.heading != blank -%}
                  <h2 class="stacked-features__heading">{{ block.settings.heading }}</h2>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <p class="stacked-features__text">{{ block.settings.text }}</p>
                {%- endif -%}
                <div class="stacked-features__buttons">
                  {%- if block.settings.button_label != blank -%}
                    <a href="{{ block.settings.button_url }}" class="btn btn--secondary">
                      {{ block.settings.button_label }}
                    </a>
                  {%- endif -%}
                  {%- if block.settings.button_label_2 != blank -%}
                    <a href="{{ block.settings.button_url_2 }}" class="btn--link">
                      {{ block.settings.button_label_2 }}
                      <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M6.158 3.135a.5.5 0 01.707.023l3.75 4a.5.5 0 010 .684l-3.75 4a.5.5 0 11-.73-.684L9.565 7.5 6.135 3.842a.5.5 0 01.023-.707z" fill="currentColor"/>
                      </svg>
                    </a>
                  {%- endif -%}
                </div>
              </div>
              <div class="stacked-features__media">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 1200 | image_tag: alt: block.settings.heading, loading: 'lazy', class: 'stacked-features__image' }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'stacked-features__image stacked-features__placeholder' }}
                {%- endif -%}
              </div>
            </div>
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
  .stacked-features {
    position: relative;
  }

  .stacked-features__wrapper {
    position: relative;
  }

  .stacked-features__panel {
    position: relative;
    border-top: 1px solid var(--color-border);
    background: var(--color-background);
  }

  .stacked-features__panel-inner {
    padding: 0 5%;
  }

  .stacked-features__header {
    padding: 0;
  }

  .stacked-features__trigger {
    display: flex;
    align-items: center;
    height: 4rem;
    width: 100%;
    gap: 1.25rem;
  }

  .stacked-features__number {
    font-weight: 600;
    font-size: 1.0625rem;
  }

  .stacked-features__trigger-title {
    font-weight: 600;
    font-size: 1.0625rem;
    margin: 0;
  }

  .stacked-features__body {
    padding: 2rem 0 2.5rem;
  }

  .stacked-features__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .stacked-features__tagline {
    font-weight: 600;
    font-size: 0.875rem;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stacked-features__heading {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1.25rem;
    line-height: 1.1;
  }

  .stacked-features__text {
    margin: 0;
    line-height: 1.6;
    font-size: 1.0625rem;
  }

  .stacked-features__buttons {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .stacked-features__image {
    width: 100%;
    height: 25rem;
    object-fit: cover;
  }

  .stacked-features__placeholder {
    background: #f5f5f5;
    height: 25rem;
  }

  @media (min-width: 768px) {
    .stacked-features__body {
      padding: 2.5rem 0 3.5rem;
    }

    .stacked-features__number {
      font-size: 1.125rem;
    }

    .stacked-features__trigger-title {
      font-size: 1.125rem;
    }
  }

  @media (min-width: 1024px) {
    .stacked-features__panel {
      position: sticky;
      top: calc(var(--panel-index) * 4rem);
    }

    .stacked-features__grid {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }

    .stacked-features__body {
      padding: 3rem 0;
    }

    .stacked-features__image {
      height: 60vh;
    }

    .stacked-features__placeholder {
      height: 60vh;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.stacked_features.name",
  "class": "section-stacked-features",
  "max_blocks": 6,
  "settings": [],
  "blocks": [
    {
      "type": "feature",
      "name": "t:sections.stacked_features.feature",
      "settings": [
        {
          "type": "text",
          "id": "trigger_title",
          "label": "t:sections.stacked_features.trigger_title",
          "default": "Clean formula"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "t:labels.button_url"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "t:labels.tagline",
          "default": "Ingredients"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading",
          "default": "No proprietary blends or filler"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "t:labels.text",
          "default": "Every ingredient is listed at its full dose. No hiding behind \"proprietary blend\" language. You know exactly what you're taking and why."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "t:labels.button_label",
          "default": "View ingredients"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "t:labels.button_url"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "t:labels.button_label_2",
          "default": "Learn more"
        },
        {
          "type": "url",
          "id": "button_url_2",
          "label": "t:labels.button_url_2"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.stacked_features.name",
      "blocks": [
        { "type": "feature", "settings": { "trigger_title": "Clean formula", "tagline": "Ingredients", "heading": "No proprietary blends or filler" } },
        { "type": "feature", "settings": { "trigger_title": "Clinically dosed", "tagline": "Science", "heading": "Doses that match the research" } },
        { "type": "feature", "settings": { "trigger_title": "Third-party tested", "tagline": "Quality", "heading": "Independent lab verification" } },
        { "type": "feature", "settings": { "trigger_title": "Money-back guarantee", "tagline": "Trust", "heading": "60-day no-questions refund" } }
      ]
    }
  ]
}
{% endschema %}
