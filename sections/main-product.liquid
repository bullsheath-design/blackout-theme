{%- assign product = product -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

<section class="main-product section-padding" {{ section.shopify_attributes }}>
  <div class="container">
    <nav aria-label="breadcrumb" class="main-product__breadcrumb">
      <ol>
        <li><a href="{{ routes.root_url }}">{{ 'sections.main_product.home' | t }}</a></li>
        <li>
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M6.158 3.135a.5.5 0 01.707.023l3.75 4a.5.5 0 010 .684l-3.75 4a.5.5 0 11-.73-.684L9.565 7.5 6.135 3.842a.5.5 0 01.023-.707z" fill="currentColor"/></svg>
        </li>
        {%- if product.collections.size > 0 -%}
          <li><a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a></li>
          <li>
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M6.158 3.135a.5.5 0 01.707.023l3.75 4a.5.5 0 010 .684l-3.75 4a.5.5 0 11-.73-.684L9.565 7.5 6.135 3.842a.5.5 0 01.023-.707z" fill="currentColor"/></svg>
          </li>
        {%- endif -%}
        <li aria-current="page">{{ product.title }}</li>
      </ol>
    </nav>

    <div class="main-product__grid">
      <div class="main-product__media">
        {%- for media in product.media -%}
          <div class="main-product__media-item{% if forloop.first %} main-product__media-item--active{% endif %}">
            {%- if media.media_type == 'image' -%}
              {{ media | image_url: width: 1200 | image_tag: alt: media.alt, loading: 'lazy', class: 'main-product__image' }}
            {%- elsif media.media_type == 'video' -%}
              {{ media | video_tag: controls: true, class: 'main-product__video' }}
            {%- elsif media.media_type == 'external_video' -%}
              {{ media | external_video_tag: class: 'main-product__video' }}
            {%- endif -%}
          </div>
        {%- else -%}
          <div class="main-product__media-item main-product__media-item--active">
            {{ 'product-1' | placeholder_svg_tag: 'main-product__image main-product__placeholder' }}
          </div>
        {%- endfor -%}

        {%- if product.media.size > 1 -%}
          <div class="main-product__thumbs">
            {%- for media in product.media -%}
              {%- if media.media_type == 'image' -%}
                <button class="main-product__thumb{% if forloop.first %} main-product__thumb--active{% endif %}" data-media-index="{{ forloop.index0 }}">
                  {{ media | image_url: width: 100, height: 100, crop: 'center' | image_tag: alt: media.alt, loading: 'lazy' }}
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="main-product__info">
        <h1 class="main-product__title">{{ product.title }}</h1>
        {%- if section.settings.show_vendor -%}
          <p class="main-product__vendor">{{ product.vendor }}</p>
        {%- endif -%}
        <p class="main-product__price" data-product-price>
          {{ current_variant.price | money }}
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <s class="main-product__compare-price">{{ current_variant.compare_at_price | money }}</s>
          {%- endif -%}
        </p>

        {%- if product.description != blank -%}
          <div class="main-product__description">{{ product.description }}</div>
        {%- endif -%}

        {% form 'product', product, class: 'main-product__form' %}
          {%- if product.variants.size > 1 -%}
            {%- for option in product.options_with_values -%}
              <div class="main-product__option">
                <label class="main-product__option-label">{{ option.name }}</label>
                <select name="id" class="main-product__select">
                  {%- for variant in product.variants -%}
                    <option
                      value="{{ variant.id }}"
                      {% if variant == current_variant %}selected{% endif %}
                      {% unless variant.available %}disabled{% endunless %}
                    >
                      {{ variant.title }} - {{ variant.price | money }}
                    </option>
                  {%- endfor -%}
                </select>
              </div>
            {%- endfor -%}
          {%- else -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
          {%- endif -%}

          <div class="main-product__quantity">
            <label for="quantity" class="main-product__option-label">{{ 'sections.main_product.quantity' | t }}</label>
            <input type="number" id="quantity" name="quantity" value="1" min="1" class="main-product__quantity-input">
          </div>

          <button
            type="submit"
            class="btn btn--primary main-product__add-to-cart"
            {% unless current_variant.available %}disabled{% endunless %}
          >
            {%- if current_variant.available -%}
              {{ 'sections.main_product.add_to_cart' | t }}
            {%- else -%}
              {{ 'sections.main_product.sold_out' | t }}
            {%- endif -%}
          </button>
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .main-product__breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem;
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    font-size: 0.875rem;
  }

  .main-product__breadcrumb a {
    opacity: 0.7;
  }

  .main-product__breadcrumb a:hover {
    opacity: 1;
  }

  .main-product__breadcrumb svg {
    opacity: 0.5;
  }

  .main-product__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .main-product__media {
    position: relative;
  }

  .main-product__media-item {
    display: none;
  }

  .main-product__media-item--active {
    display: block;
  }

  .main-product__image,
  .main-product__video {
    width: 100%;
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
  }

  .main-product__placeholder {
    background: #f5f5f5;
  }

  .main-product__thumbs {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    overflow-x: auto;
  }

  .main-product__thumb {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    border: 2px solid transparent;
    background: none;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
  }

  .main-product__thumb--active {
    border-color: var(--color-foreground);
  }

  .main-product__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .main-product__title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  .main-product__vendor {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.6;
    margin: 0 0 1rem;
  }

  .main-product__price {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .main-product__compare-price {
    font-size: 1.125rem;
    opacity: 0.5;
    font-weight: 400;
  }

  .main-product__description {
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .main-product__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .main-product__option-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .main-product__select,
  .main-product__quantity-input {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    background: transparent;
    font-family: inherit;
    font-size: 0.9375rem;
  }

  .main-product__quantity-input {
    max-width: 100px;
  }

  .main-product__add-to-cart {
    width: 100%;
  }

  .main-product__add-to-cart:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media (min-width: 1024px) {
    .main-product__grid {
      grid-template-columns: 1.25fr 0.75fr;
      gap: 5rem;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    var section = document.querySelector('.main-product');
    if (!section) return;

    var thumbs = section.querySelectorAll('.main-product__thumb');
    var items = section.querySelectorAll('.main-product__media-item');

    thumbs.forEach(function(thumb) {
      thumb.addEventListener('click', function() {
        var index = parseInt(this.getAttribute('data-media-index'));
        items.forEach(function(item) { item.classList.remove('main-product__media-item--active'); });
        thumbs.forEach(function(t) { t.classList.remove('main-product__thumb--active'); });
        if (items[index]) items[index].classList.add('main-product__media-item--active');
        this.classList.add('main-product__thumb--active');
      });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.main_product.name",
  "class": "section-main-product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:sections.main_product.show_vendor",
      "default": true
    }
  ]
}
{% endschema %}
