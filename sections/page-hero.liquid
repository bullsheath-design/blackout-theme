<section
  class="page-hero section-padding"
  style="--text-align: {{ section.settings.text_alignment }};"
  {{ section.shopify_attributes }}
>
  <div class="container page-hero__inner">
    {%- if section.settings.tagline != blank -%}
      <p class="page-hero__tagline">{{ section.settings.tagline }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="page-hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p class="page-hero__description">{{ section.settings.description }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <div class="page-hero__buttons">
        <a href="{{ section.settings.button_url }}" class="btn btn--primary">
          {{ section.settings.button_label }}
        </a>
        {%- if section.settings.button_label_2 != blank -%}
          <a href="{{ section.settings.button_url_2 }}" class="btn btn--secondary">
            {{ section.settings.button_label_2 }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .page-hero__inner {
    max-width: 600px;
    text-align: var(--text-align, center);
  }

  .page-hero__tagline {
    font-weight: 600;
    font-size: 0.875rem;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .page-hero__heading {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    margin-bottom: 1.25rem;
    line-height: 1.1;
  }

  .page-hero__description {
    font-size: 1.0625rem;
    margin: 0;
    line-height: 1.6;
    opacity: 0.8;
  }

  .page-hero__buttons {
    display: flex;
    align-items: center;
    justify-content: var(--text-align, center);
    gap: 1rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  @media (min-width: 768px) {
    .page-hero__buttons {
      margin-top: 2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.page_hero.name",
  "class": "section-page-hero",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "t:labels.tagline"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Page title"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:labels.button_url"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "t:labels.button_label_2"
    },
    {
      "type": "url",
      "id": "button_url_2",
      "label": "t:labels.button_url_2"
    },
    {
      "type": "text_alignment",
      "id": "text_alignment",
      "label": "t:labels.alignment",
      "default": "center"
    }
  ],
  "presets": [
    {
      "name": "t:sections.page_hero.name"
    }
  ]
}
{% endschema %}
