<section class="testimonial-carousel section-padding" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="testimonial-carousel__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="testimonial-carousel__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="testimonial-carousel__description">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    <div class="testimonial-carousel__track" role="region" aria-roledescription="carousel" aria-label="{{ 'sections.testimonial_carousel.label' | t }}">
      <div class="testimonial-carousel__slides">
        {%- for block in section.blocks -%}
          <div
            class="testimonial-carousel__slide"
            role="group"
            aria-roledescription="slide"
            {{ block.shopify_attributes }}
          >
            <div class="testimonial-card">
              <div class="testimonial-card__stars" aria-label="{{ block.settings.rating }} {{ 'sections.testimonial_carousel.out_of_5' | t }}">
                {%- for i in (1..5) -%}
                  {%- if i <= block.settings.rating -%}
                    <svg class="testimonial-card__star testimonial-card__star--filled" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M21.947 9.179a1.001 1.001 0 00-.868-.676l-5.701-.453-2.467-5.461a.998.998 0 00-1.822-.001L8.622 8.05l-5.701.453a1 1 0 00-.619 1.713l4.213 4.107-1.49 6.452a1 1 0 001.53 1.057L12 18.202l5.445 3.63a1.001 1.001 0 001.517-1.106l-1.829-6.4 4.536-4.082c.297-.268.406-.686.278-1.065z" fill="currentColor"/>
                    </svg>
                  {%- else -%}
                    <svg class="testimonial-card__star" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M21.947 9.179a1.001 1.001 0 00-.868-.676l-5.701-.453-2.467-5.461a.998.998 0 00-1.822-.001L8.622 8.05l-5.701.453a1 1 0 00-.619 1.713l4.213 4.107-1.49 6.452a1 1 0 001.53 1.057L12 18.202l5.445 3.63a1.001 1.001 0 001.517-1.106l-1.829-6.4 4.536-4.082c.297-.268.406-.686.278-1.065z" fill="currentColor"/>
                    </svg>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              {%- if block.settings.quote != blank -%}
                <blockquote class="testimonial-card__quote">{{ block.settings.quote }}</blockquote>
              {%- endif -%}
              <div class="testimonial-card__author">
                {%- if block.settings.avatar != blank -%}
                  {{ block.settings.avatar | image_url: width: 96, height: 96, crop: 'center' | image_tag: alt: block.settings.name, loading: 'lazy', class: 'testimonial-card__avatar' }}
                {%- endif -%}
                <div>
                  {%- if block.settings.name != blank -%}
                    <p class="testimonial-card__name">{{ block.settings.name }}</p>
                  {%- endif -%}
                  {%- if block.settings.title != blank -%}
                    <p class="testimonial-card__title">{{ block.settings.title }}</p>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- if section.blocks.size > 2 -%}
        <button class="testimonial-carousel__btn testimonial-carousel__btn--prev" aria-label="{{ 'sections.testimonial_carousel.previous' | t }}">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12.707 17.293L8.414 13H18v-2H8.414l4.293-4.293-1.414-1.414L4.586 12l6.707 6.707z"/>
          </svg>
        </button>
        <button class="testimonial-carousel__btn testimonial-carousel__btn--next" aria-label="{{ 'sections.testimonial_carousel.next' | t }}">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z"/>
          </svg>
        </button>
      {%- endif -%}
    </div>

    <div class="testimonial-carousel__dots">
      {%- for block in section.blocks -%}
        <button
          class="testimonial-carousel__dot{% if forloop.first %} testimonial-carousel__dot--active{% endif %}"
          aria-label="{{ 'sections.testimonial_carousel.go_to_slide' | t: number: forloop.index }}"
          data-dot-index="{{ forloop.index0 }}"
        ></button>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .testimonial-carousel__header {
    max-width: 600px;
    margin: 0 auto 3rem;
    text-align: center;
  }

  .testimonial-carousel__heading {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .testimonial-carousel__description {
    font-size: 1.0625rem;
    margin: 0;
    opacity: 0.8;
  }

  .testimonial-carousel__track {
    position: relative;
    overflow: hidden;
  }

  .testimonial-carousel__slides {
    display: flex;
    transition: transform 0.4s ease;
  }

  .testimonial-carousel__slide {
    flex: 0 0 100%;
    min-width: 0;
    padding: 0;
  }

  .testimonial-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    border: 1px solid var(--color-border);
    padding: 1.5rem;
    height: 100%;
  }

  .testimonial-card__stars {
    display: flex;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .testimonial-card__star {
    width: 24px;
    height: 24px;
    margin-right: 2px;
    color: #d4d4d4;
  }

  .testimonial-card__star--filled {
    color: #000;
  }

  .testimonial-card__quote {
    font-size: 1.0625rem;
    line-height: 1.6;
    margin: 0 0 1.5rem;
    font-style: normal;
  }

  .testimonial-card__author {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .testimonial-card__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
  }

  .testimonial-card__name {
    font-weight: 600;
    margin: 0;
  }

  .testimonial-card__title {
    margin: 0;
    font-size: 0.875rem;
    opacity: 0.7;
  }

  .testimonial-carousel__btn {
    display: none;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-background);
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 2;
  }

  .testimonial-carousel__btn--prev { left: 0; }
  .testimonial-carousel__btn--next { right: 0; }

  .testimonial-carousel__dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 2rem;
  }

  .testimonial-carousel__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: #d4d4d4;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s ease;
  }

  .testimonial-carousel__dot--active {
    background: var(--color-foreground);
  }

  @media (min-width: 768px) {
    .testimonial-carousel__slide {
      flex: 0 0 50%;
      padding: 0 1rem;
    }

    .testimonial-carousel__slides {
      margin: 0 -1rem;
    }

    .testimonial-card {
      padding: 2rem;
    }

    .testimonial-carousel__btn {
      display: flex;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function() {
    var section = document.querySelector('.testimonial-carousel');
    if (!section) return;

    var track = section.querySelector('.testimonial-carousel__slides');
    var slides = section.querySelectorAll('.testimonial-carousel__slide');
    var prevBtn = section.querySelector('.testimonial-carousel__btn--prev');
    var nextBtn = section.querySelector('.testimonial-carousel__btn--next');
    var dots = section.querySelectorAll('.testimonial-carousel__dot');
    var current = 0;
    var isMobile = window.innerWidth < 768;
    var perView = isMobile ? 1 : 2;
    var maxIndex = Math.max(0, slides.length - perView);

    function update() {
      var offset = current * (100 / perView);
      track.style.transform = 'translateX(-' + offset + '%)';
      dots.forEach(function(dot, i) {
        dot.classList.toggle('testimonial-carousel__dot--active', i === current);
      });
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', function() {
        current = Math.max(0, current - 1);
        update();
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function() {
        current = Math.min(maxIndex, current + 1);
        update();
      });
    }

    dots.forEach(function(dot, i) {
      dot.addEventListener('click', function() {
        current = Math.min(i, maxIndex);
        update();
      });
    });

    window.addEventListener('resize', function() {
      isMobile = window.innerWidth < 768;
      perView = isMobile ? 1 : 2;
      maxIndex = Math.max(0, slides.length - perView);
      if (current > maxIndex) current = maxIndex;
      update();
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.testimonial_carousel.name",
  "class": "section-testimonial-carousel",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Customer testimonials"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:labels.description"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "t:sections.testimonial_carousel.testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "t:sections.testimonial_carousel.rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "t:sections.testimonial_carousel.quote",
          "default": "\"I've tested everything. Blackout is the only brand that delivers exactly what the label says.\""
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "t:sections.testimonial_carousel.avatar"
        },
        {
          "type": "text",
          "id": "name",
          "label": "t:sections.testimonial_carousel.author_name",
          "default": "Marcus Chen"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.testimonial_carousel.author_title",
          "default": "Competitive powerlifter"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.testimonial_carousel.name",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
