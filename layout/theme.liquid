<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="">
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-5GJD6226');</script>
    <!-- End Google Tag Manager -->
    {% if template.name == "product" %}
      <link rel="canonical" href="{{ shop.url }}/products/{{ product.handle }}">
    {% elsif template.name == "collection" %}
      <link rel="canonical" href="{{ canonical_url | split: '?' | first }}">
    {% else %}
      <link rel="canonical" href="{{ canonical_url }}">
    {% endif %}

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% if template.name == 'blog' and current_tags %}
      <meta name="robots" content="noindex, follow">
    {% endif %}

    {%- if template.name == 'index' -%}
      <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@graph": [
            {
              "@type": "Organization",
              "@id": "{{ shop.url }}/#organization",
              "name": "{{ shop.name }}",
              "url": "{{ shop.url }}",
              {%- if settings.social_instagram != blank or settings.social_facebook != blank or settings.social_youtube != blank or settings.social_tiktok != blank -%}
              "sameAs": [
                {%- assign sameAs_items = '' -%}
                {%- if settings.social_instagram != blank -%}{%- assign sameAs_items = sameAs_items | append: '"' | append: settings.social_instagram | append: '",' -%}{%- endif -%}
                {%- if settings.social_facebook != blank -%}{%- assign sameAs_items = sameAs_items | append: '"' | append: settings.social_facebook | append: '",' -%}{%- endif -%}
                {%- if settings.social_youtube != blank -%}{%- assign sameAs_items = sameAs_items | append: '"' | append: settings.social_youtube | append: '",' -%}{%- endif -%}
                {%- if settings.social_tiktok != blank -%}{%- assign sameAs_items = sameAs_items | append: '"' | append: settings.social_tiktok | append: '",' -%}{%- endif -%}
                {{ sameAs_items | remove_last: ',' }}
              ],
              {%- endif -%}
              "description": "{{ shop.name }} — premium performance supplements engineered for athletes who demand more."
            },
            {
              "@type": "WebSite",
              "@id": "{{ shop.url }}/#website",
              "name": "{{ shop.name }}",
              "url": "{{ shop.url }}",
              "publisher": {
                "@id": "{{ shop.url }}/#organization"
              },
              "potentialAction": {
                "@type": "SearchAction",
                "target": {
                  "@type": "EntryPoint",
                  "urlTemplate": "{{ shop.url }}/search?q={search_term_string}"
                },
                "query-input": "required name=search_term_string"
              }
            }
          ]
        }
      </script>
    {%- endif -%}

    {%- if template.name == 'collection' or template.name == 'product' or template.name == 'article' -%}
      <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Home",
              "item": "{{ shop.url }}"
            }
            {%- if template.name == 'collection' and collection.handle -%}
              ,{
                "@type": "ListItem",
                "position": 2,
                "name": "{{ collection.title | escape }}",
                "item": "{{ shop.url }}{{ collection.url }}"
              }
            {%- elsif template.name == 'product' -%}
              {%- if collection -%}
                ,{
                  "@type": "ListItem",
                  "position": 2,
                  "name": "{{ collection.title | escape }}",
                  "item": "{{ shop.url }}{{ collection.url }}"
                },{
                  "@type": "ListItem",
                  "position": 3,
                  "name": "{{ product.title | escape }}",
                  "item": "{{ shop.url }}{{ product.url }}"
                }
              {%- else -%}
                ,{
                  "@type": "ListItem",
                  "position": 2,
                  "name": "{{ product.title | escape }}",
                  "item": "{{ shop.url }}{{ product.url }}"
                }
              {%- endif -%}
            {%- elsif template.name == 'article' -%}
              ,{
                "@type": "ListItem",
                "position": 2,
                "name": "{{ blog.title | escape }}",
                "item": "{{ shop.url }}{{ blog.url }}"
              },{
                "@type": "ListItem",
                "position": 3,
                "name": "{{ article.title | escape }}",
                "item": "{{ shop.url }}{{ article.url }}"
              }
            {%- endif -%}
          ]
        }
      </script>
    {%- endif -%}

    {%- if template.name == 'article' -%}
      <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "Article",
          "headline": "{{ article.title | escape }}",
          "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' }}",
          "dateModified": "{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%SZ' }}",
          "author": {
            "@type": "Organization",
            "name": "{{ shop.name }}"
          },
          "publisher": {
            "@type": "Organization",
            "name": "{{ shop.name }}",
            "url": "{{ shop.url }}"
          }
        }
      </script>
    {%- endif -%}

    {%- if template.name == 'collection' -%}
      <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "ItemList",
          "itemListElement": [
            {%- for product in collection.products -%}
            {
              "@type": "ListItem",
              "position": {{ forloop.index }},
              "url": "{{ shop.url }}{{ product.url }}"
            }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          ]
        }
      </script>
    {%- endif -%}

    
    {{ content_for_header }}

    <style>
      :root {
        --color-background: {{ settings.color_background }};
        --color-foreground: {{ settings.color_foreground }};
        --color-primary: {{ settings.color_primary }};
        --color-secondary: {{ settings.color_secondary }};
        --color-accent: {{ settings.color_accent }};
        --color-border: {{ settings.color_border }};
        --font-body-family: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
        --font-heading-family: {{ settings.type_header_font.family }}, {{ settings.type_header_font.fallback_families }};
        --font-body-weight: {{ settings.type_body_font.weight }};
        --font-heading-weight: {{ settings.type_header_font.weight }};
        --content-grid: minmax(5%, 1fr) minmax(0, 1200px) minmax(5%, 1fr);
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: var(--font-body-family);
        font-weight: var(--font-body-weight);
        color: var(--color-foreground);
        background-color: var(--color-background);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading-family);
        font-weight: var(--font-heading-weight);
        line-height: 1.2;
        margin: 0;
      }

      img {
        max-width: 100%;
        height: auto;
        display: block;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button {
        cursor: pointer;
        font-family: inherit;
      }

      .container {
        width: 100%;
        max-width: 1920px;
        margin-left: auto;
        margin-right: auto;
        padding-left: 20px;
        padding-right: 20px;
      }

      @media (min-width: 768px) {
        .container {
          padding-left: 45px;
          padding-right: 45px;
        }
      }

      .section-padding {
        padding-left: 5%;
        padding-right: 5%;
        padding-top: 4rem;
        padding-bottom: 4rem;
      }

      @media (min-width: 768px) {
        .section-padding {
          padding-top: 6rem;
          padding-bottom: 6rem;
        }
      }

      @media (min-width: 1024px) {
        .section-padding {
          padding-top: 7rem;
          padding-bottom: 7rem;
        }
      }

      .btn {
        display: inline-flex;
        gap: 0.75rem;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
        transition: all 0.2s ease;
        padding: 0.75rem 1.5rem;
        border: 1px solid var(--color-border);
        font-weight: 600;
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .btn:focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 2px;
      }

      .btn--primary {
        background-color: var(--color-foreground);
        color: var(--color-background);
        border-color: var(--color-foreground);
      }

      .btn--primary:hover {
        opacity: 0.85;
      }

      .btn--secondary {
        background-color: transparent;
        color: var(--color-foreground);
        border-color: var(--color-border);
      }

      .btn--secondary:hover {
        background-color: var(--color-foreground);
        color: var(--color-background);
      }

      .btn--link {
        border: none;
        padding: 0;
        gap: 0.5rem;
        font-weight: 600;
      }

      .btn--link:hover {
        gap: 0.75rem;
      }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        border: 0;
      }

      {{ settings.type_body_font | font_face: font_display: 'swap' }}
      {{ settings.type_header_font | font_face: font_display: 'swap' }}
    </style>
  </head>

  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5GJD6226"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <a class="visually-hidden" href="#main-content">
      {{ 'general.accessibility.skip_to_content' | t }}
    </a>

    {% sections 'header-group' %}

    <main id="main-content" role="main">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    <script>
      (function() {
        document.addEventListener('click', function(e) {
          var el = e.target.closest('a[href*="/checkout"], button[name="checkout"], input[name="checkout"]');
          if (!el) return;
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ ecommerce: null });
          window.dataLayer.push({ event: 'begin_checkout' });
        });
      })();
    </script>
  </body>
</html>
